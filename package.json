{
  "name": "pesas-hub-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run db:up && npm run db:wait && npx --yes tsx@4.20.5 scripts/dev-local.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib middleware.ts next.config.ts tailwind.config.ts",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose --env-file infra/.env -f infra/docker-compose.dev.yml up -d",
    "db:down": "docker compose --env-file infra/.env -f infra/docker-compose.dev.yml down",
    "db:logs": "docker compose --env-file infra/.env -f infra/docker-compose.dev.yml logs -f mariadb",
    "db:status": "npx --yes tsx@4.20.5 scripts/db-status.ts",
    "db:wait": "npx --yes tsx@4.20.5 scripts/db-wait.ts",
    "db:migrate": "npx --yes tsx@4.20.5 scripts/db-migrate.ts",
    "db:seed": "npx --yes tsx@4.20.5 scripts/db-seed.ts",
    "db:reset": "npx --yes tsx@4.20.5 scripts/db-reset.ts --database=dev",
    "db:test:reset": "npx --yes tsx@4.20.5 scripts/db-reset.ts --database=test",
    "db:legacy:reset": "npx --yes tsx@4.20.5 scripts/db-reset.ts --database=legacy",
    "db:permissions": "npx --yes tsx@4.20.5 scripts/db-permissions.ts",
    "db:bootstrap:smoke": "npx --yes tsx@4.20.5 scripts/db-bootstrap-smoke.ts",
    "autonomy:live": "npx --yes tsx@4.20.5 scripts/commercial-live-autonomy-run.ts",
    "e2e:autonomous": "npx --yes tsx@4.20.5 scripts/e2e-autonomous-harness.ts",
    "test": "npx --yes tsx@4.20.5 --test \"tests/**/*.test.ts\"",
    "worker:outbox": "npx --yes tsx@4.20.5 scripts/autonomous-outbox-worker.ts",
    "worker:followup": "npx --yes tsx@4.20.5 scripts/autonomous-followup-worker.ts",
    "customer-identity:evaluate": "npx --yes tsx@4.20.5 scripts/customer-identity/evaluate-candidates.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "mysql2": "^3.11.5",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
