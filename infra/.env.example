APP_ENV=development

# Single DB env contract (INFRA-01).
# DB_HOST/DB_PORT/DB_NAME are shared across every target (one local MariaDB
# instance; DB_NAME is only a required-field fallback for the migration/test/
# legacy targets, which always override the actual database name from
# scripts/db-utils.ts#getTargetDatabaseName anyway).
# DB_USER/DB_PASSWORD are intentionally NOT set: lib/database-config.ts's
# alias resolution makes DB_USER/DB_PASSWORD win over every *_DATABASE_USER/
# *_DATABASE_PASSWORD, which would make crm_dev_admin (migration/test targets)
# unreachable. Each target keeps its own *_USER/*_PASSWORD instead:
#   app target       -> DATABASE_USER / DATABASE_PASSWORD / DATABASE_NAME
#   migration target -> MIGRATION_DATABASE_USER / MIGRATION_DATABASE_PASSWORD
#   test target      -> TEST_DATABASE_USER / TEST_DATABASE_PASSWORD
#   legacy target     -> LEGACY_DATABASE_USER / LEGACY_DATABASE_PASSWORD
# CRM_APP_PASSWORD is infra-only: consumed by infra/mariadb/init/002-*.sh via
# docker-compose to provision the crm_app MariaDB user. It must always carry
# the same value as DATABASE_PASSWORD below.
MARIADB_ROOT_PASSWORD=una_clave_root_local
CRM_DEV_ADMIN_PASSWORD=una_clave_admin_local
CRM_APP_PASSWORD=una_clave_local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=main_management

DATABASE_NAME=main_management
DATABASE_USER=crm_app
DATABASE_PASSWORD=una_clave_local

MIGRATION_DATABASE_USER=crm_dev_admin
MIGRATION_DATABASE_PASSWORD=una_clave_admin_local
TEST_DATABASE_USER=crm_dev_admin
TEST_DATABASE_PASSWORD=una_clave_admin_local
LEGACY_DATABASE_USER=crm_app
LEGACY_DATABASE_PASSWORD=una_clave_local

DB_WRITE_ENABLED=true
AI_SDR_EXECUTION_MODE=shadow
