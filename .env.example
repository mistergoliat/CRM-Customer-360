APP_ENV=development

# Single DB env contract (INFRA-01).
# DB_HOST/DB_PORT/DB_NAME are shared across every target (one local MariaDB
# instance; DB_NAME is only a required-field fallback for the migration/test/
# legacy targets, which always override the actual database name from
# scripts/db-utils.ts#getTargetDatabaseName anyway).
# DB_USER/DB_PASSWORD are intentionally NOT set: lib/database-config.ts's
# alias resolution makes DB_USER/DB_PASSWORD win over every *_DATABASE_USER/
# *_DATABASE_PASSWORD, which would make crm_dev_admin (migration/test targets)
# unreachable. Each target keeps its own *_USER/*_PASSWORD instead:
#   app target       -> DATABASE_USER / DATABASE_PASSWORD / DATABASE_NAME
#   migration target -> MIGRATION_DATABASE_USER / MIGRATION_DATABASE_PASSWORD
#   test target      -> TEST_DATABASE_USER / TEST_DATABASE_PASSWORD
#   legacy target     -> LEGACY_DATABASE_USER / LEGACY_DATABASE_PASSWORD
# CRM_APP_PASSWORD is infra-only: consumed by infra/mariadb/init/002-*.sh via
# docker-compose to provision the crm_app MariaDB user. It must always carry
# the same value as DATABASE_PASSWORD below.
MARIADB_ROOT_PASSWORD=una_clave_root_local
CRM_DEV_ADMIN_PASSWORD=una_clave_admin_local
CRM_APP_PASSWORD=una_clave_local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=main_management

DATABASE_NAME=main_management
DATABASE_USER=crm_app
DATABASE_PASSWORD=una_clave_local

MIGRATION_DATABASE_USER=crm_dev_admin
MIGRATION_DATABASE_PASSWORD=una_clave_admin_local
TEST_DATABASE_USER=crm_dev_admin
TEST_DATABASE_PASSWORD=una_clave_admin_local
LEGACY_DATABASE_USER=crm_app
LEGACY_DATABASE_PASSWORD=una_clave_local

META_GRAPH_API_VERSION=v22.0
META_ACCESS_TOKEN=replace-with-meta-token
DEFAULT_PHONE_NUMBER_ID=replace-with-phone-number-id
# Brain Meta send adapter (source of truth for the new adapter; disabled by default; keep explicit before sandbox/manual use)
BRAIN_META_GRAPH_VERSION=v25.0
BRAIN_META_SEND_ENABLED=false
BRAIN_META_SEND_TEST_ENABLED=false
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_DEFAULT_PHONE_NUMBER_ID=
# Brain outbox worker skeleton (disabled by default; no polling and no real send in P1I-004)
BRAIN_OUTBOX_WORKER_ENABLED=false
BRAIN_OUTBOX_WORKER_ALLOW_REAL_SEND=false
BRAIN_OUTBOX_WORKER_BATCH_SIZE=10
BRAIN_OUTBOX_WORKER_LOCK_SECONDS=60
# Brain outbox worker contract v2 (explicit transport and retry controls; disabled by default)
BRAIN_MESSAGE_TRANSPORT_ENABLED=false
BRAIN_OUTBOX_LEASE_SECONDS=60
BRAIN_OUTBOX_MAX_ATTEMPTS=5
BRAIN_OUTBOX_RETRY_BASE_SECONDS=30
BRAIN_OUTBOX_RETRY_MAX_SECONDS=3600
# Brain WhatsApp transport adapter contract (sandbox only; no live Meta send)
BRAIN_WHATSAPP_TRANSPORT_ENABLED=false
BRAIN_WHATSAPP_TRANSPORT_SANDBOX=true
BRAIN_WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
BRAIN_WHATSAPP_GRAPH_API_VERSION=
BRAIN_WHATSAPP_PHONE_NUMBER_ID=
BRAIN_WHATSAPP_ACCESS_TOKEN=
BRAIN_WHATSAPP_TIMEOUT_MS=10000
# Optional. Allows processInbound to stage a planned outbox row under strict flags only.
BRAIN_PROCESS_INBOUND_ALLOW_OUTBOX_PLAN=false
# Canonical outbound persistence after successful backend send (disabled by default)
BRAIN_PERSIST_CANONICAL_OUTBOUND=false
# Minimal case summary refresh after successful backend send (disabled by default)
BRAIN_UPDATE_CASE_AFTER_BACKEND_SEND=false
APP_BASE_URL=http://localhost:3010
# Required. Secret used only to sign hub_session cookies.
SESSION_SECRET=
N8N_BASE_URL=https://n8n.pesaschile.cl
# Required. Token used only for admin login.
ADMIN_BYPASS_TOKEN=
# Required for n8n/backend machine-to-machine calls to POST /api/ai/orchestrate.
# Use as: Authorization: Bearer <AI_ORCHESTRATION_API_TOKEN>
AI_ORCHESTRATION_API_TOKEN=
# Optional. Keep false unless the shadow log table exists and shadow logging is explicitly being tested.
AI_ORCHESTRATOR_SHADOW_LOG_ENABLED=false
# Optional. Enables the real Knowledge Agent model path when true.
BRAIN_ENABLE_REAL_MODEL=false
# Optional. Enables the real HTTP Sales Agent provider/runtime when true.
BRAIN_SALES_AGENT_ENABLED=false
# Optional. Set false to run the Sales Agent runtime in live mode.
BRAIN_SALES_AGENT_DRY_RUN=true
# Optional. Enables commercial shadow evaluation from processInbound.
BRAIN_COMMERCIAL_SHADOW_ENABLED=false
# Optional. Enables the Sales Agent runtime inside commercial shadow evaluation.
BRAIN_COMMERCIAL_RUNTIME_ENABLED=false
# Optional. Enables the commercial policy pass after Sales Agent output.
BRAIN_COMMERCIAL_POLICY_ENABLED=false
# Optional. Allows commercial shadow evaluation to resolve the HTTP provider from BRAIN_MODEL_*.
BRAIN_COMMERCIAL_SHADOW_ALLOW_REAL_PROVIDER=false
# Optional. Live model budget for the commercial runtime. Keep short for webhooks; raise for local stress tests.
BRAIN_COMMERCIAL_SHADOW_TIMEOUT_MS=5000
BRAIN_COMMERCIAL_CONTEXT_TIMEOUT_MS=1500
BRAIN_COMMERCIAL_RUNTIME_TIMEOUT_MS=3000
BRAIN_COMMERCIAL_POLICY_TIMEOUT_MS=1000
# Optional. Enables the commercial operational loop after shadow evaluation.
BRAIN_COMMERCIAL_OPERATIONAL_LOOP_ENABLED=false
# Optional. Allows autonomous operational loop/action queue to run even when the sales consultative service also handled the inbound.
BRAIN_COMMERCIAL_AUTONOMY_AFTER_CONSULTATIVE_ENABLED=false
# Optional. Keeps commercial state persistence disabled by default.
BRAIN_COMMERCIAL_STATE_PERSISTENCE_ENABLED=false
# Optional. Keeps the durable agent action queue disabled by default.
BRAIN_AGENT_ACTION_QUEUE_ENABLED=false
# Optional. Keeps durable agent action persistence disabled by default.
BRAIN_AGENT_ACTION_PERSISTENCE_ENABLED=false
# Optional. Keeps sandbox autonomy disabled by default.
BRAIN_AUTONOMOUS_SANDBOX_ENABLED=false
# Optional. Keeps autonomous reply disabled by default.
BRAIN_AUTONOMOUS_REPLY_ENABLED=false
# Optional. Sandbox whitelist for test WA IDs only.
BRAIN_AUTONOMOUS_TEST_WA_IDS=
# Optional. Same allowlist purpose as BRAIN_AUTONOMOUS_TEST_WA_IDS, checked by
# the WhatsApp webhook route in addition to it (union of both). During a
# controlled pilot this ALSO blocks inbound persistence from any sender not
# listed here (not only outbound sends) - leave both empty in production.
BRAIN_WHATSAPP_ALLOWED_WA_IDS=
# Optional. Sandbox action allowlist for autonomy preview only.
BRAIN_AUTONOMOUS_ALLOWED_ACTION_TYPES=send_whatsapp_reply,request_more_context
# Optional. Sandbox risk ceiling for autonomy preview only.
BRAIN_AUTONOMOUS_MAX_RISK_LEVEL=low
# Optional. Keeps the end-to-end scenario simulator disabled by default.
BRAIN_SCENARIO_SIMULATOR_ENABLED=false
# Optional. Keeps execute_fake disabled unless explicitly allowed in development.
BRAIN_SCENARIO_SIMULATOR_ALLOW_EXECUTE_FAKE=false
# Optional. Keeps the execution gate disabled by default.
BRAIN_EXECUTION_GATE_ENABLED=false
# Optional. Keeps the outbox bridge disabled by default.
BRAIN_OUTBOX_BRIDGE_ENABLED=false
# Optional. When false, the processInbound execution bridge can use the current wa_id as a local test recipient without a static whitelist.
BRAIN_EXECUTION_GATE_SANDBOX_REQUIRED=false
# Optional. Keeps ConversationRequest tracking (multi-request runtime, migration 015) disabled by default.
BRAIN_REQUEST_TRACKING_ENABLED=false
# Optional. Keeps durable TurnPlan persistence (migration 016) disabled by default.
BRAIN_TURN_PLAN_PERSISTENCE_ENABLED=false
# Optional. Master switch for the multi-request runtime; requires REQUEST_TRACKING + TURN_PLAN_PERSISTENCE.
BRAIN_MULTI_REQUEST_RUNTIME_ENABLED=false
# Optional. Keeps request-scoped fact persistence (migration 017) disabled by default; requires REQUEST_TRACKING.
BRAIN_REQUEST_FACTS_ENABLED=false
# Optional. Keeps customer addresses (migration 018) disabled by default; requires REQUEST_TRACKING + REQUEST_FACTS.
BRAIN_CUSTOMER_ADDRESSES_ENABLED=false
# Optional. Keeps the operator pilot shell disabled by default.
BRAIN_OPERATOR_PILOT_ENABLED=false
# Optional. Keeps pilot command stubs blocked by default.
BRAIN_OPERATOR_PILOT_COMMANDS_ENABLED=false
# Optional. OpenAI-compatible endpoint used only when BRAIN_ENABLE_REAL_MODEL=true.
# Example values for DeepSeek V4 Flash (any OpenAI-compatible provider also works):
#   BRAIN_MODEL_API_URL=https://api.deepseek.com/chat/completions
#   BRAIN_MODEL_NAME=deepseek-v4-flash
BRAIN_MODEL_API_URL=
BRAIN_MODEL_API_KEY=
BRAIN_MODEL_NAME=brain-knowledge
BRAIN_MODEL_TIMEOUT_MS=15000
# Optional. Foundation-only executor guard. Keep false until the real outbox/messaging layer exists.
BRAIN_EXECUTOR_ENABLED=false
# Optional. Never enable in P1I. Real sends remain disabled by design.
BRAIN_EXECUTOR_ALLOW_REAL_SEND=false
DB_WRITE_ENABLED=true
AI_SDR_EXECUTION_MODE=shadow
